{% assign latest_posts_size = site.posts | size %}
{% if latest_posts_size > 0 %}
  {% if site.latest_posts.limit %}
    {% assign latest_posts_limit = site.latest_posts.limit %}
  {% else %}
    {% assign latest_posts_limit = 3 %}
  {% endif %}
  <div class="home-posts">
    {% for item in site.posts limit: latest_posts_limit %}
      {% if item.redirect == blank %}
        {% assign post_href = item.url | relative_url %}
        {% assign post_external = false %}
      {% elsif item.redirect contains '://' %}
        {% assign post_href = item.redirect %}
        {% assign post_external = true %}
      {% else %}
        {% assign post_href = item.redirect | relative_url %}
        {% assign post_external = false %}
      {% endif %}
      <a class="home-post-card" href="{{ post_href }}"{% if post_external %} target="_blank" rel="noopener"{% endif %}>
        {% if item.thumbnail %}
          <div class="home-post-thumb">
            <img src="{{ item.thumbnail | relative_url }}" alt="{{ item.title | strip_html }}" loading="lazy">
          </div>
        {% else %}
          <div class="home-post-thumb home-post-thumb--placeholder">
            <i class="fa-solid fa-feather-pointed"></i>
          </div>
        {% endif %}
        <div class="home-post-body">
          {% if item.publication_type %}
            <span class="home-post-kind">{{ item.publication_type }}</span>
          {% endif %}
          <h3 class="home-post-title">{{ item.title }}</h3>
          {% if item.description %}
            <p class="home-post-description">{{ item.description | strip_html | truncate: 150 }}</p>
          {% endif %}
          <div class="home-post-meta">
            <span><i class="fa-regular fa-calendar"></i> {{ item.date | date: '%b %-d, %Y' }}</span>
            {% if item.tags and item.tags.size > 0 %}
              <span class="home-post-tag"><i class="fa-solid fa-hashtag"></i>{{ item.tags | first }}</span>
            {% endif %}
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
{% else %}
  <p>No posts so far...</p>
{% endif %}
